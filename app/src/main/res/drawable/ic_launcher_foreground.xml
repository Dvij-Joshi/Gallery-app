<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Outer glass ring glow -->
    <path
        android:pathData="M 54,26 A 28,28 0 1,1 53.99,26 Z"
        android:strokeWidth="1.5"
        android:strokeColor="#33FFFFFF" />

    <!-- Core Aperture Blades structure inside safe zone -->
    <path
        android:pathData="M 54,34 L 70,44 L 62,64 L 42,64 L 38,48 Z"
        android:strokeWidth="1"
        android:strokeColor="#40FFFFFF">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="38"
                android:startY="34"
                android:endX="70"
                android:endY="64"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF7A00" />
                <item android:offset="0.5" android:color="#FF007A" />
                <item android:offset="1.0" android:color="#7A00FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Center prism lens reflection -->
    <path
        android:pathData="M 54,42 L 64,54 L 54,60 L 44,54 Z"
        android:fillColor="#FFFFFFFF" />
        
    <!-- Reflection sparkle flares -->
    <path
        android:pathData="M 72,36 L 74,38 M 74,36 L 72,38"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:strokeColor="#CCFFFFFF" />
        
    <path
        android:pathData="M 36,70 L 38,72 M 38,70 L 36,72"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:strokeColor="#80FFFFFF" />
</vector>
